{
  "name": "gate-qa",
  "version": "1.0.0",
  "private": true,
  "homepage": "https://superawat.github.io/Gate_QA/",
  "dependencies": {
    "@testing-library/jest-dom": "^5.16.5",
    "@testing-library/react": "^13.4.0",
    "@testing-library/user-event": "^13.5.0",
    "better-react-mathjax": "^2.0.2",
    "dompurify": "^3.3.1",
    "framer-motion": "^12.38.0",
    "katex": "^0.16.7",
    "rc-slider": "^11.1.9",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-icons": "^4.8.0",
    "react-router-dom": "^6.30.1",
    "react-select": "^5.7.3",
    "recharts": "^3.8.1"
  },
  "scripts": {
    "precompute": "node scripts/precompute-subtopics.mjs",
    "pipeline:readiness": "node scripts/pipeline/readiness-dry-run.mjs",
    "pipeline:readiness:2027": "node scripts/pipeline/readiness-dry-run.mjs --year 2027",
    "pipeline:scrape-upvotes": "node scripts/pipeline/scrape-upvotes-browser.mjs --limit 100 --resume",
    "pipeline:global-difficulty": "node scripts/pipeline/extract-global-difficulty.mjs",
    "pipeline:global-difficulty:merge-upvotes": "node scripts/pipeline/extract-global-difficulty.mjs --merge audit/gateoverflow-upvotes.json",
    "aptitude:scrape-aptitude": "node scripts/aptitude-pipeline/scrape-aptitude.mjs",
    "aptitude:scrape-aptitude:long": "node scripts/aptitude-pipeline/scrape-aptitude.mjs --resume --max-runtime-minutes 180 --max-new-papers 500 --concurrency 2 --request-timeout 45000 --delay 1500 --checkpoint-every 10",
    "aptitude:mirror-images": "node scripts/aptitude-pipeline/mirror-aptitude-images.mjs",
    "aptitude:optimize-images": "node scripts/optimize-aptitude-images-webp.mjs",
    "aptitude:build-aptitude": "node scripts/aptitude-pipeline/scrape-aptitude.mjs --resume && python scripts/aptitude-pipeline/build_aptitude_db.py && npm run aptitude:mirror-images && npm run aptitude:optimize-images && npm run qa:validate-aptitude && npm run qa:verify-aptitude && npm run qa:validate-aptitude-images",
    "aptitude:build-only": "python scripts/aptitude-pipeline/build_aptitude_db.py && npm run aptitude:mirror-images && npm run aptitude:optimize-images && npm run qa:validate-aptitude && npm run qa:verify-aptitude && npm run qa:validate-aptitude-images",
    "mirror:question-images": "node scripts/mirror-gateoverflow-images.mjs",
    "build:public-artifacts": "node scripts/mirror-gateoverflow-images.mjs && node scripts/build-public-artifacts.mjs",
    "start": "node scripts/precompute-subtopics.mjs && node scripts/build-public-artifacts.mjs && node scripts/deployment/sync-calculator.mjs --public && vite",
    "build": "node scripts/precompute-subtopics.mjs && node scripts/build-public-artifacts.mjs && node scripts/deployment/sync-calculator.mjs --public && vite build && node scripts/deployment/ensure-nojekyll.mjs && node scripts/deployment/sync-calculator.mjs --dist",
    "analyze:bundle": "node scripts/precompute-subtopics.mjs && node scripts/build-public-artifacts.mjs && node scripts/deployment/sync-calculator.mjs --public && vite build --mode analyze",
    "serve": "vite preview",
    "qa:audit-historical-papers": "node scripts/qa/historical-paper-audit.js",
    "qa:audit-pre-2010-gateoverflow": "node scripts/qa/pre-2010-gateoverflow-audit.js",
    "qa:import-missing-paper": "node scripts/qa/import-missing-paper-from-tag.js",
    "qa:import-external-aptitude": "node --max-old-space-size=4096 scripts/qa/import-external-aptitude.mjs --write",
    "qa:backfill-gateoverflow-top-answers": "node scripts/qa/backfill-gateoverflow-top-answers.mjs --write",
    "qa:resolve-legacy-answer-gaps": "node scripts/qa/resolve-legacy-answer-gaps.mjs --write",
    "qa:repair-pre-2010-questions": "node scripts/qa/repair-pre-2010-questions.js",
    "qa:repair-historical-exam-uids": "node scripts/qa/repair-historical-exam-uids.js",
    "qa:repair-historical-paper-counts": "node scripts/qa/repair-historical-paper-counts.js",
    "qa:validate-data": "node scripts/qa/validate-data.js",
    "qa:validate-aptitude": "node scripts/qa/validate-aptitude-data.js",
    "qa:audit-aptitude": "node scripts/qa/audit-aptitude-data.js",
    "qa:audit-aptitude-eduquity-2025": "node scripts/qa/audit-aptitude-eduquity-2025.js",
    "qa:verify-aptitude": "node scripts/qa/verify-aptitude-quality.js",
    "qa:validate-aptitude-images": "node scripts/qa/validate-aptitude-images.mjs",
    "qa:validate-question-images": "node scripts/qa/validate-question-images.mjs",
    "qa:recheck-gateoverflow-pyqs": "npm run qa:audit-historical-papers && npm run qa:audit-pre-2010-gateoverflow && node scripts/qa/gateoverflow-answer-coverage.js && node scripts/qa/assert-gateoverflow-recheck.js",
    "qa:validate-bundle-budget": "node scripts/qa/validate-bundle-budget.mjs",
    "qa:validate-landing-network": "node scripts/qa/validate-landing-network.mjs",
    "qa:validate-public-parity": "node scripts/qa/validate-public-parity.js",
    "test:unit": "npm run precompute && vitest run",
    "test:e2e": "playwright test",
    "test:e2e:headed": "playwright test --headed",
    "test:watch": "vitest",
    "qa:a11y:axe": "playwright test tests/e2e/a11y.axe.spec.js",
    "lighthouse:mobile": "lhci autorun --config=./lighthouserc.json",
    "qa:all": "npm run test:unit && npm run qa:validate-data && npm run build && npm run test:e2e && npm run qa:validate-bundle-budget && npm run qa:validate-landing-network && npm run lighthouse:mobile && npm run qa:validate-public-parity"
  },
  "eslintConfig": {
    "extends": [
      "react-app",
      "react-app/jest"
    ]
  },
  "browserslist": {
    "production": [
      ">0.2%",
      "not dead",
      "not op_mini all"
    ],
    "development": [
      "last 1 chrome version",
      "last 1 firefox version",
      "last 1 safari version"
    ]
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.10.2",
    "@lhci/cli": "^0.15.1",
    "@playwright/test": "^1.56.1",
    "@vitejs/plugin-react": "^5.1.4",
    "autoprefixer": "^10.4.14",
    "axe-core": "^4.10.3",
    "jsdom": "^28.1.0",
    "postcss": "^8.4.23",
    "rollup-plugin-visualizer": "^7.0.1",
    "sharp": "^0.34.5",
    "tailwindcss": "^3.3.2",
    "vite": "^7.3.1",
    "vitest": "^3.2.4"
  }
}
