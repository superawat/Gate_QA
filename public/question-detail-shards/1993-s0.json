    "go:2300": {
      "title": "GATE CSE 1993 | Question: 8.2",
      "year": "gate1993",
      "link": "https://gateoverflow.in/2300/gate-cse-1993-question-8-2",
      "question": "<p>The proposition $p \\wedge (\\sim p \\vee q)$ is:</p>\n<ol style=\"list-style-type:upper-alpha\">\n<li>\n<p>a tautology</p>\n</li>\n<li>\n<p>logically equivalent to $p \\wedge q$</p>\n</li>\n<li>\n<p>logically equivalent to $p \\vee q$</p>\n</li>\n<li>\n<p>a contradiction</p>\n</li>\n<li>\n<p>none of the above</p>\n</li>\n</ol>",
      "tags": [
        "gate1993",
        "mathematical-logic",
        "easy",
        "propositional-logic"
