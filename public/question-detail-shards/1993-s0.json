    "go:2294": {
      "title": "GATE CSE 1993 | Question: 7.6",
      "year": "gate1993",
      "link": "https://gateoverflow.in/2294/gate-cse-1993-question-7-6",
      "question": "<p>A simple two-pass assembler does the following in the first pass:</p>\n<ol style=\"list-style-type:upper-alpha\">\n<li>\n<p>It allocates space for the literals.</p>\n</li>\n<li>\n<p>It computes the total length of the program.</p>\n</li>\n<li>\n<p>It builds the symbol table for the symbols and their values.</p>\n</li>\n<li>\n<p>It generates code for all the load and store register instructions.</p>\n</li>\n<li>\n<p>None of the above.</p>\n</li>\n</ol>",
      "tags": [
        "gate1993",
        "compiler-design",
        "assembler",
        "easy",
        "multiple-selects"
      ],
