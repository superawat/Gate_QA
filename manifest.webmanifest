{
  "name": "GateQA",
  "short_name": "GateQA",
  "description": "Practice GATE CSE previous-year questions with local-first filters, solving workflows, mock tests, and revision insights.",
  "start_url": "/Gate_QA/",
  "scope": "/Gate_QA/",
  "display": "standalone",
  "launch_handler": {
    "client_mode": "navigate-existing"
  },
  "file_handlers": [
    {
      "action": "/Gate_QA/",
      "accept": {
        "application/json": [".gateqa"]
      }
    }
  ],
  "background_color": "#eef4fb",
  "theme_color": "#0f172a",
  "icons": [
    {
      "src": "/Gate_QA/logo.png",
      "sizes": "192x192",
      "type": "image/png",
      "purpose": "any"
    },
    {
      "src": "/Gate_QA/logo.png",
      "sizes": "512x512",
      "type": "image/png",
      "purpose": "any"
    }
  ]
}
